{
  "name": "vue-text-tooltip",
  "version": "0.0.9",
  "description": "A Vue 3 tooltip component for displaying text overflow with automatic ellipsis",
  "private": false,
  "keywords": [
    "tooltip",
    "vue-tooltip",
    "vue-text-tooltip",
    "text-ellipsis",
    "vue3"
  ],
  "files": [
    "dist"
  ],
  "module": "./dist/es/index.js",
  "main": "./dist/lib/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/es/index.js",
      "require": "./dist/lib/index.js"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "pub": "npm publish --access=public",
    "typecheck": "vue-tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kangdy/vue-tooltip.git"
  },
  "dependencies": {
    "@popperjs/core": "^2.11.8"
  },
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.7.0",
    "vue": "^3.4.0",
    "vue-tsc": "^2.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
